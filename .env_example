#================================================================================
# BotRunner Environment Configuration
# Copy this file to .env and fill in your values
#================================================================================

#------------------------------------- Environment -------------------------------------
ENVIRONMENT = "development"  # development, staging, production
DEBUG = false

#------------------------------------- Database Configuration -------------------------------------
DATABASE_URL =                     # Database connection string (for Neon PostgreSQL)
DATABASE = "SQLite"                # "neon" or "SQLite"

#------------------------------------- Vector DB -------------------------------------
VECTORDB = "chromadb"              # "chromadb" or "qdrant"
DATABASE_PATH =                    # Path to Raw_Data_Collection for vector DB

# Qdrant (if using Qdrant as vector DB)
QDRANT_HOST = 
QDRANT_PORT = 

#------------------------------------- OpenAI Configuration -------------------------------------
OPENAI_API_KEY = 
OPENAI_BASE_URL = "https://api.openai.com/v1"

#------------------------------------- Azure OpenAI Configuration -------------------------------------
AZURE_OPENAI_KEY = 
AZURE_OPENAI_ENDPOINT = 
AZURE_API_VERSION = "2025-04-01-preview"
AZURE_OPENAI_MODEL_NAME = "gpt-4.1"

#------------------------------------- Gemini Configuration -------------------------------------
GEMINI_API_KEY = 
GEMINI_BASE_URL = 
GEMINI_MODEL_NAME = "gemini-3-flash-preview"

#------------------------------------- Model Configuration -------------------------------------
# Primary chat model - main conversational agent (Azure)
PRIMARY_MODEL = "azure/gpt-5.1-chat"

# Guardrail model - for input/output validation (Azure, smaller/faster model)
GUARDRAIL_MODEL = "azure/gpt-4.1-nano"

# Summarizer model - for chat summarization and executive summaries (Azure)
SUMMARIZER_MODEL = "azure/gpt-4.1-nano"

# Azure API version for gpt-4.1-nano (guardrail & summarizer)
AZURE_NANO_API_VERSION = "2025-01-01-preview"

# OpenAI fallback models (used when Azure primary fails)
OPENAI_FALLBACK_PRIMARY_MODEL = "gpt-5.1-chat-latest"
OPENAI_FALLBACK_GUARDRAIL_MODEL = "gpt-4.1-nano"
OPENAI_FALLBACK_SUMMARIZER_MODEL = "gpt-4.1-nano"

GEMINI_FALLBACK_MODEL = "gemini/gemini-3-flash-preview"

#------------------------------------- Embedding & Reranking -------------------------------------
EMBEDDING_MODEL = "text-embedding-3-small"

AZURE_EMBED_ENDPOINT = 
AZURE_INFERENCE_CREDENTIAL = 

AZURE_CROSS_ENCODER_ENDPOINT = 
AZURE_CROSS_ENCODER_CREDENTIAL = 

COHERE_RERANKER_API_KEY = 
COHERE_URL = 

#------------------------------------- Observability (Opik) -------------------------------------
OPIK_PROJECT_NAME = 
OPIK_WORKSPACE = 

#------------------------------------- Summarizer Settings -------------------------------------
SUMMRIZE_CONTEXT_LENGTH = 3        # Number of message pairs before triggering summarization
SUMMRIZE_KEEP_LAST_N_TURNS = 3     # Number of recent turns to keep verbatim

#------------------------------------- Prompt Caching -------------------------------------
ENABLE_PROMPT_CACHING = true       # Enable prompt prefix caching (reduces input token costs by ~50%)

#------------------------------------- History Settings -------------------------------------
MAX_HISTORY = 15                   # Maximum chat history messages to retain